[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/NotebookScreen.gd" id="1_notebook"]

[node name="NotebookScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_notebook")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.09, 0.11, 0.13, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="TopBar" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2

[node name="Title" type="Label" parent="Margin/Root/TopBar"]
layout_mode = 2
size_flags_horizontal = 3
text = "Lab Notebook (Phase 7)"
theme_override_font_sizes/font_size = 24

[node name="PublishButton" type="Button" parent="Margin/Root/TopBar"]
unique_name_in_owner = true
layout_mode = 2
text = "Publish selected"

[node name="ExportButton" type="Button" parent="Margin/Root/TopBar"]
layout_mode = 2
text = "Export notebook"

[node name="Status" type="Label" parent="Margin/Root"]
unique_name_in_owner = true
layout_mode = 2
text = ""
theme_override_colors/font_color = Color(0.6, 0.8, 0.65, 1)
theme_override_font_sizes/font_size = 12

[node name="HBox" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="EntryList" type="ItemList" parent="Margin/Root/HBox"]
unique_name_in_owner = true
custom_minimum_size = Vector2(320, 0)
layout_mode = 2
size_flags_vertical = 3

[node name="DetailPanel" type="PanelContainer" parent="Margin/Root/HBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Scroll" type="ScrollContainer" parent="Margin/Root/HBox/DetailPanel"]
layout_mode = 2

[node name="Detail" type="RichTextLabel" parent="Margin/Root/HBox/DetailPanel/Scroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
bbcode_enabled = true
fit_content = true

[node name="BackButton" type="Button" parent="Margin/Root"]
layout_mode = 2
size_flags_horizontal = 0
text = "Back to Dashboard"

[connection signal="item_selected" from="Margin/Root/HBox/EntryList" to="." method="_on_entry_list_item_selected"]
[connection signal="pressed" from="Margin/Root/TopBar/PublishButton" to="." method="_on_publish_pressed"]
[connection signal="pressed" from="Margin/Root/TopBar/ExportButton" to="." method="_on_export_pressed"]
[connection signal="pressed" from="Margin/Root/BackButton" to="." method="_on_back_pressed"]
