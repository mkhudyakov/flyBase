[node name="WildMaleButton" type="Button" parent="Margin/Root/HBox/Buttons"]
layout_mode = 2
text = "Wild-type male"

[node name="WhiteMaleButton" type="Button" parent="Margin/Root/HBox/Buttons"]
layout_mode = 2
text = "white-eyed male (X-linked)"

[node name="VgHomButton" type="Button" parent="Margin/Root/HBox/Buttons"]
layout_mode = 2
text = "vestigial homozygous"

[node name="VgCarrierButton" type="Button" parent="Margin/Root/HBox/Buttons"]
layout_mode = 2
text = "vestigial carrier (het)"

[node name="AntpHetButton" type="Button" parent="Margin/Root/HBox/Buttons"]
layout_mode = 2
text = "Antennapedia dominant (het)"

[node name="Sep" type="HSeparator" parent="Margin/Root/HBox/Buttons"]
layout_mode = 2

[node name="SaveReloadButton" type="Button" parent="Margin/Root/HBox/Buttons"]
layout_mode = 2
text = "Save & Reload this fly"

[node name="OutputPanel" type="PanelContainer" parent="Margin/Root/HBox"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Scroll" type="ScrollContainer" parent="Margin/Root/HBox/OutputPanel"]
layout_mode = 2

[node name="Output" type="RichTextLabel" parent="Margin/Root/HBox/OutputPanel/Scroll"]
