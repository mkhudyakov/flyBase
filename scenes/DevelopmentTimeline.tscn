[node name="BicoidButton" type="Button" parent="Margin/Root/HBox/Controls"]
layout_mode = 2
text = "bicoid (axis, lethal)"

[node name="Sep1" type="HSeparator" parent="Margin/Root/HBox/Controls"]
layout_mode = 2

[node name="TempLabel" type="Label" parent="Margin/Root/HBox/Controls"]
unique_name_in_owner = true
layout_mode = 2
