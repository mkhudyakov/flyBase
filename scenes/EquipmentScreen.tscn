[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/EquipmentScreen.gd" id="1_equip"]

[node name="EquipmentScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_equip")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.09, 0.11, 0.13, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Margin/Root"]
layout_mode = 2
text = "Equipment & Upgrades (Phase 11)"
theme_override_font_sizes/font_size = 24

[node name="Stats" type="Label" parent="Margin/Root"]
unique_name_in_owner = true
layout_mode = 2
text = ""
theme_override_colors/font_color = Color(0.85, 0.82, 0.6, 1)

[node name="Scroll" type="ScrollContainer" parent="Margin/Root"]
layout_mode = 2
size_flags_vertical = 3

[node name="EquipmentList" type="VBoxContainer" parent="Margin/Root/Scroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="Status" type="Label" parent="Margin/Root"]
unique_name_in_owner = true
layout_mode = 2
text = ""
theme_override_colors/font_color = Color(0.7, 0.82, 0.85, 1)

[node name="BackButton" type="Button" parent="Margin/Root"]
layout_mode = 2
size_flags_horizontal = 0
text = "Back to Dashboard"

[connection signal="pressed" from="Margin/Root/BackButton" to="." method="_on_back_pressed"]
