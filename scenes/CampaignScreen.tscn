[node name="Scroll" type="ScrollContainer" parent="Margin/Root/HBox/DetailPanel"]
layout_mode = 2

[node name="DetailVBox" type="VBoxContainer" parent="Margin/Root/HBox/DetailPanel/Scroll"]
