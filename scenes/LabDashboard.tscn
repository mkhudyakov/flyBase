[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/LabDashboard.gd" id="1_dashboard"]

[node name="LabDashboard" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_dashboard")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.09, 0.11, 0.13, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 20
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 20
theme_override_constants/margin_bottom = 16

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="TopBar" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Margin/Root/TopBar"]
layout_mode = 2
text = "Lab Dashboard"
theme_override_font_sizes/font_size = 24

[node name="Spacer" type="Control" parent="Margin/Root/TopBar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="LabStats" type="Label" parent="Margin/Root/TopBar"]
unique_name_in_owner = true
layout_mode = 2
text = ""
theme_override_colors/font_color = Color(0.7, 0.8, 0.85, 1)

[node name="SaveButton" type="Button" parent="Margin/Root/TopBar"]
layout_mode = 2
text = "Save Lab"

[node name="LoadButton" type="Button" parent="Margin/Root/TopBar"]
layout_mode = 2
text = "Load Lab"

[node name="BackButton" type="Button" parent="Margin/Root/TopBar"]
layout_mode = 2
text = "Menu"

[node name="LastEvent" type="Label" parent="Margin/Root"]
unique_name_in_owner = true
layout_mode = 2
text = ""
theme_override_colors/font_color = Color(0.6, 0.8, 0.65, 1)
theme_override_font_sizes/font_size = 13

[node name="Main" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="VialsPanel" type="VBoxContainer" parent="Margin/Root/Main"]
custom_minimum_size = Vector2(300, 0)
layout_mode = 2
theme_override_constants/separation = 6

[node name="Header" type="Label" parent="Margin/Root/Main/VialsPanel"]
layout_mode = 2
text = "Vials"
theme_override_font_sizes/font_size = 16

[node name="VialList" type="ItemList" parent="Margin/Root/Main/VialsPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="VialButtons" type="HBoxContainer" parent="Margin/Root/Main/VialsPanel"]
layout_mode = 2

[node name="NewVialButton" type="Button" parent="Margin/Root/Main/VialsPanel/VialButtons"]
layout_mode = 2
size_flags_horizontal = 3
text = "New vial"

[node name="ArchiveButton" type="Button" parent="Margin/Root/Main/VialsPanel/VialButtons"]
layout_mode = 2
size_flags_horizontal = 3
text = "Archive"

[node name="DetailPanel" type="VBoxContainer" parent="Margin/Root/Main"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="VialNameLabel" type="Label" parent="Margin/Root/Main/DetailPanel"]
unique_name_in_owner = true
layout_mode = 2
text = "No vial selected"
theme_override_font_sizes/font_size = 18

[node name="VialSummary" type="RichTextLabel" parent="Margin/Root/Main/DetailPanel"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 52)
layout_mode = 2
bbcode_enabled = true
fit_content = true

[node name="IncubatorRow" type="HBoxContainer" parent="Margin/Root/Main/DetailPanel"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="IncLabel" type="Label" parent="Margin/Root/Main/DetailPanel/IncubatorRow"]
layout_mode = 2
text = "Incubator:"

[node name="IncubatorOption" type="OptionButton" parent="Margin/Root/Main/DetailPanel/IncubatorRow"]
unique_name_in_owner = true
custom_minimum_size = Vector2(220, 0)
layout_mode = 2

[node name="FliesHeader" type="Label" parent="Margin/Root/Main/DetailPanel"]
layout_mode = 2
text = "Flies"
theme_override_font_sizes/font_size = 16

[node name="FlyList" type="ItemList" parent="Margin/Root/Main/DetailPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="Actions" type="HBoxContainer" parent="Margin/Root/Main/DetailPanel"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="BreedButton" type="Button" parent="Margin/Root/Main/DetailPanel/Actions"]
layout_mode = 2
text = "Breed (50)"

[node name="InspectButton" type="Button" parent="Margin/Root/Main/DetailPanel/Actions"]
layout_mode = 2
text = "Inspect fly"

[node name="MoveLabel" type="Label" parent="Margin/Root/Main/DetailPanel/Actions"]
layout_mode = 2
text = "→"

[node name="MoveTargetOption" type="OptionButton" parent="Margin/Root/Main/DetailPanel/Actions"]
unique_name_in_owner = true
custom_minimum_size = Vector2(160, 0)
layout_mode = 2

[node name="MoveButton" type="Button" parent="Margin/Root/Main/DetailPanel/Actions"]
layout_mode = 2
text = "Move fly"

[node name="IncubatorPanel" type="VBoxContainer" parent="Margin/Root/Main"]
custom_minimum_size = Vector2(260, 0)
layout_mode = 2
theme_override_constants/separation = 6

[node name="Header" type="Label" parent="Margin/Root/Main/IncubatorPanel"]
layout_mode = 2
text = "Incubators"
theme_override_font_sizes/font_size = 16

[node name="IncubatorList" type="ItemList" parent="Margin/Root/Main/IncubatorPanel"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3

[node name="IncTempLabel" type="Label" parent="Margin/Root/Main/IncubatorPanel"]
unique_name_in_owner = true
layout_mode = 2
text = "Temperature"

[node name="IncTempSlider" type="HSlider" parent="Margin/Root/Main/IncubatorPanel"]
unique_name_in_owner = true
layout_mode = 2
min_value = 8.0
max_value = 36.0
step = 1.0
value = 25.0

[node name="ToolsBar" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="ToolsLabel" type="Label" parent="Margin/Root/ToolsBar"]
layout_mode = 2
