[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/LabDashboard.gd" id="1_dashboard"]

[node name="LabDashboard" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_dashboard")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.09, 0.11, 0.13, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 32
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 32
theme_override_constants/margin_bottom = 24

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="InfoLabel" type="RichTextLabel" parent="Margin/VBox"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
fit_content = true

[node name="ButtonsBox" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="GenotypeDebugButton" type="Button" parent="Margin/VBox/ButtonsBox"]
layout_mode = 2
text = "Genotype Debug"

[node name="PhenotypeViewerButton" type="Button" parent="Margin/VBox/ButtonsBox"]
layout_mode = 2
text = "Phenotype Viewer"

[node name="MicroscopeButton" type="Button" parent="Margin/VBox/ButtonsBox"]
layout_mode = 2
text = "Microscope Viewer"

[node name="DevelopmentButton" type="Button" parent="Margin/VBox/ButtonsBox"]
layout_mode = 2
text = "Development Timeline"

[node name="TestSaveButton" type="Button" parent="Margin/VBox/ButtonsBox"]
layout_mode = 2
text = "Test Save (autosave)"

[node name="TestLoadButton" type="Button" parent="Margin/VBox/ButtonsBox"]
layout_mode = 2
text = "Test Load (autosave)"

[node name="BackButton" type="Button" parent="Margin/VBox/ButtonsBox"]
layout_mode = 2
text = "Back to Menu"

[connection signal="pressed" from="Margin/VBox/ButtonsBox/GenotypeDebugButton" to="." method="_on_genotype_debug_pressed"]
[connection signal="pressed" from="Margin/VBox/ButtonsBox/PhenotypeViewerButton" to="." method="_on_phenotype_viewer_pressed"]
[connection signal="pressed" from="Margin/VBox/ButtonsBox/MicroscopeButton" to="." method="_on_microscope_pressed"]
[connection signal="pressed" from="Margin/VBox/ButtonsBox/DevelopmentButton" to="." method="_on_development_pressed"]
[connection signal="pressed" from="Margin/VBox/ButtonsBox/TestSaveButton" to="." method="_on_test_save_pressed"]
[connection signal="pressed" from="Margin/VBox/ButtonsBox/TestLoadButton" to="." method="_on_test_load_pressed"]
[connection signal="pressed" from="Margin/VBox/ButtonsBox/BackButton" to="." method="_on_back_pressed"]
