[node name="TraitLabel" type="Label" parent="Margin/Root/Controls"]
layout_mode = 2
text = "Histogram trait:"

[node name="TraitOption" type="OptionButton" parent="Margin/Root/Controls"]
unique_name_in_owner = true
custom_minimum_size = Vector2(180, 0)
layout_mode = 2

[node name="ChartRow" type="HBoxContainer" parent="Margin/Root"]
custom_minimum_size = Vector2(0, 280)
layout_mode = 2
theme_override_constants/separation = 12

[node name="PhenoPanel" type="PanelContainer" parent="Margin/Root/ChartRow"]
layout_mode = 2
