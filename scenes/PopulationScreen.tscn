[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/PopulationScreen.gd" id="1_pop"]

[node name="PopulationScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_pop")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.09, 0.11, 0.13, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 20
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 20

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Margin/Root"]
layout_mode = 2
text = "Population Simulation (Phase 10)"
theme_override_font_sizes/font_size = 24

[node name="Controls" type="HBoxContainer" parent="Margin/Root"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="FounderOption" type="OptionButton" parent="Margin/Root/Controls"]
unique_name_in_owner = true
custom_minimum_size = Vector2(230, 0)
layout_mode = 2

[node name="SelectionOption" type="OptionButton" parent="Margin/Root/Controls"]
unique_name_in_owner = true
custom_minimum_size = Vector2(200, 0)
layout_mode = 2

[node name="GenOption" type="OptionButton" parent="Margin/Root/Controls"]
unique_name_in_owner = true
custom_minimum_size = Vector2(140, 0)
layout_mode = 2

[node name="Bottleneck" type="CheckBox" parent="Margin/Root/Controls"]
unique_name_in_owner = true
layout_mode = 2
text = "Bottleneck @ gen 4"

[node name="RunButton" type="Button" parent="Margin/Root/Controls"]
layout_mode = 2
text = "Run"

[node name="TempLabel" type="Label" parent="Margin/Root"]
unique_name_in_owner = true
layout_mode = 2
text = "Temperature: 25 °C"

[node name="TempSlider" type="HSlider" parent="Margin/Root"]
unique_name_in_owner = true
custom_minimum_size = Vector2(320, 0)
layout_mode = 2
size_flags_horizontal = 0
min_value = 16.0
max_value = 36.0
step = 1.0
value = 25.0

[node name="OutputPanel" type="PanelContainer" parent="Margin/Root"]
layout_mode = 2
size_flags_vertical = 3

[node name="Scroll" type="ScrollContainer" parent="Margin/Root/OutputPanel"]
layout_mode = 2

[node name="Output" type="RichTextLabel" parent="Margin/Root/OutputPanel/Scroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
bbcode_enabled = true
fit_content = true

[node name="BackButton" type="Button" parent="Margin/Root"]
layout_mode = 2
size_flags_horizontal = 0
text = "Back to Dashboard"

[connection signal="pressed" from="Margin/Root/Controls/RunButton" to="." method="_on_run_pressed"]
[connection signal="pressed" from="Margin/Root/BackButton" to="." method="_on_back_pressed"]
